-$ gh epicsBy vilmibm  #=> gh issue list --author="vilmibm" --label="epic"
-
-$ gh alias set --shell igrep 'gh issue list --label="$1" | grep "$2"'
-$ gh igrep epic foo  #=> gh issue list --label="epic" | grep "foo"
-
-.EE
